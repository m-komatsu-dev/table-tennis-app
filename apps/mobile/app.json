{
  "expo": {
    "name": "Table Tennis Record",
    "slug": "table-tennis-record",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "tabletennis",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
