{
  "expo": {
    "name": "Table Tennis Log",
    "slug": "table-tennis-record",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "tabletennis",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc"
      },
      "package": "com.mkomatsu.tabletennislog"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "727ff23e-2953-47ab-867a-e53c502d2c51"
      }
    }
  }
}
