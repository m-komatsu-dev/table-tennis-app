generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  COMPETITIVE
  PRO
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NO_ANSWER
}

enum MatchType {
  PRACTICE
  OFFICIAL
  TOURNAMENT
}

enum MatchResult {
  WIN
  LOSE
  DRAW
}

enum PracticeMenuCategory {
  SERVE
  RECEIVE
  FOREHAND
  BACKHAND
  FOOTWORK
  DRIVE
  BLOCK
  GAME
  PHYSICAL
  MENTAL
  OTHER
}

enum PartnerPostType {
  PRACTICE
  MATCH
}

enum PartnerPostStatus {
  OPEN
  CLOSED
}

enum PartnerRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ReportTargetType {
  USER
  PARTNER_POST
  PARTNER_REQUEST
  CHAT_MESSAGE
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  PERSONAL_INFORMATION
  FAKE_INFORMATION
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  username             String?  @unique
  name                 String
  passwordHash         String?
  googleId             String?  @unique
  level                Level    @default(BEGINNER)
  playStyle            String?
  club                 String?
  avatarUrl            String?
  gender               Gender?
  publicProfileEnabled Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  practiceLogs    PracticeLog[]
  practiceMenus   PracticeMenu[]
  matchRecords    MatchRecord[]
  equipment       Equipment[]
  partnerPosts    PartnerPost[]
  partnerRequests PartnerRequest[]
  chatMessages    ChatMessage[]
  chatReadStates  ChatReadState[]
  reportsSubmitted Report[]
  blocksCreated    UserBlock[] @relation("UserBlocksCreated")
  blocksReceived   UserBlock[] @relation("UserBlocksReceived")
}

model PracticeLog {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  practicedAt    DateTime
  durationMin    Int
  location       String?
  content        String?
  equipmentId    String?
  equipment      Equipment?    @relation(fields: [equipmentId], references: [id])
  practiceMenuId String?
  practiceMenu   PracticeMenu? @relation(fields: [practiceMenuId], references: [id], onDelete: SetNull)
  isPublic       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PracticeMenu {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  goal         String?
  totalMinutes Int?
  isTemplate   Boolean            @default(true)
  items        PracticeMenuItem[]
  practiceLogs PracticeLog[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model PracticeMenuItem {
  id             String               @id @default(uuid())
  practiceMenuId String
  practiceMenu   PracticeMenu         @relation(fields: [practiceMenuId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  category       PracticeMenuCategory
  durationMin    Int?
  order          Int
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model MatchRecord {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipmentId  String?
  equipment    Equipment?  @relation(fields: [equipmentId], references: [id])
  opponentName String
  opponentTeam String?
  matchType    MatchType   @default(PRACTICE)
  scores       Json
  result       MatchResult
  memo         String?
  isPublic     Boolean     @default(false)
  playedAt     DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Equipment {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blade             String
  rubberFh          String?
  rubberFhThickness String?
  rubberBh          String?
  rubberBhThickness String?
  gripType          String?
  isCurrent         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceLogs PracticeLog[]
  matchRecords MatchRecord[]
}

model PartnerPost {
  id            String            @id @default(uuid())
  ownerId       String
  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type          PartnerPostType
  title         String
  area          String?
  preferredTime String?
  level         String?
  purpose       String?
  message       String?
  status        PartnerPostStatus @default(OPEN)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requests PartnerRequest[]

  @@index([status, createdAt])
  @@index([ownerId, createdAt])
}

model PartnerRequest {
  id          String               @id @default(uuid())
  postId      String
  requesterId String
  message     String?
  status      PartnerRequestStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  post      PartnerPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  requester User        @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  chatRoom  ChatRoom?

  @@unique([postId, requesterId])
  @@index([requesterId, createdAt])
}

model ChatRoom {
  id               String   @id @default(uuid())
  partnerRequestId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  partnerRequest PartnerRequest @relation(fields: [partnerRequestId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
  readStates     ChatReadState[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([senderId])
}

model ChatReadState {
  id         String   @id @default(uuid())
  roomId     String
  userId     String
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@index([roomId])
}

model Report {
  id              String           @id @default(uuid())
  reporterId      String
  targetType      ReportTargetType
  targetUserId    String?
  targetPostId    String?
  targetRequestId String?
  targetMessageId String?
  reason          ReportReason
  details         String?
  status          ReportStatus     @default(OPEN)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([targetUserId])
  @@index([targetPostId])
  @@index([targetMessageId])
  @@index([status])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}
