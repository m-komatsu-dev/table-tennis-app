{
  "name": "table-tennis-platform",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @table-tennis/web",
    "build": "npm run build -w @table-tennis/web",
    "lint": "npm run lint -w @table-tennis/web",
    "typecheck": "npm run typecheck -w @table-tennis/web",
    "test": "npm run test -w @table-tennis/web",
    "test:watch": "npm run test:watch -w @table-tennis/web",
    "vercel-build": "npm run prisma:generate && npm run build -w @table-tennis/web",
    "prisma:generate": "npm run prisma:generate -w @table-tennis/db",
    "prisma:migrate": "npm run prisma:migrate -w @table-tennis/db",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy -w @table-tennis/db",
    "prisma:studio": "npm run prisma:studio -w @table-tennis/db",
    "db:seed": "npm run db:seed -w @table-tennis/db"
  },
  "devDependencies": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.1",
    "@rollup/rollup-linux-x64-gnu": "4.62.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
